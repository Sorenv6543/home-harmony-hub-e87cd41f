{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.32",
        "--browser=chromium",
        "--viewport-size=1440,900",
        "--ignore-https-errors",
        "--allowed-origins=http://localhost:8080"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      }
    }
  }
}